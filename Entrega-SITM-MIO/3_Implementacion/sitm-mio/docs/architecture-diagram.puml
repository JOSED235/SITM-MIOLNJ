@startuml SITM-MIO_Architecture_Complete

' ============================================================
' CONFIG GLOBAL — líneas rectas ortogonales
' ============================================================
!theme plain
skinparam linetype ortho
skinparam backgroundColor #FFFFFF
skinparam defaultFontSize 11
skinparam defaultFontName Arial
skinparam padding 6
skinparam ranksep 60
skinparam nodesep 40

skinparam node {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  BorderThickness 2
  FontStyle bold
}
skinparam component {
  BackgroundColor #FFF9C4
  BorderColor #F57F17
  BorderThickness 1
}
skinparam database {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
}
skinparam artifact {
  BackgroundColor #FCE4EC
  BorderColor #B71C1C
}
skinparam package {
  BorderColor #6A1B9A
  BorderThickness 2
  FontStyle bold
}
skinparam note {
  BackgroundColor #FFFDE7
  BorderColor #F9A825
}
skinparam arrow {
  Color #37474F
  FontSize 9
}
skinparam file {
  BackgroundColor #F3E5F5
  BorderColor #6A1B9A
}

title "SITM-MIO — Diagrama de Despliegue Completo\nZeroC Ice 3.7.10  ·  Java 17  ·  Gradle 8.6  ·  Leaflet.js 1.9.4"

' ============================================================
' ARCHIVOS DE DATOS (CSV)
' ============================================================
package "Datos de Entrada — CSV (/opt/sitm-mio/ o data/)" as DATA_PKG #F5F5F5 {
  file "datagrams-MiniPilot.csv\n(dataset piloto)" as CSV_MINI
  file "datagrams4Pilot.csv\n(9x MiniPilot)" as CSV_FULL
  file "lines-241-ActiveGT.csv\n(241 rutas activas)" as CSV_LINES
}

' ============================================================
' CONTRATOS ICE — sitm.ice
' ============================================================
package "contracts — Contratos Compartidos (sitm.ice  →  Ice-Builder  →  Java)" as CONTRACTS_PKG #FFF3E0 {
  artifact "contracts.jar" as CONTRACTS_JAR

  note right of CONTRACTS_JAR
    interfaces Ice generadas:
    ─ DatagramReceiver
       postDatagram(Datagram)
       subscribe(MonitoringSubscriber*)
    ─ ArchiveService  [ami]
       archiveDatagram(Datagram)
    ─ MonitoringSubscriber
       updateLocation(BusUpdate)
    ─ ReportProvider
       getAverageSpeed(lineId,month,year)
       getMonthlyReports(year)
    ─ SpeedWorker
       computeSpeeds(DatagramSeq) : SpeedReportSeq
    structs: Datagram, BusUpdate,
             Location, SpeedReport
  end note
}

' ============================================================
' SUBSISTEMA A — MONITOREO EN TIEMPO REAL
' ============================================================
package "Subsistema A — Monitoreo en Tiempo Real  (patrón Pub-Sub + AMI)" as MON_PKG #E8F5E9 {

  node "Nodo Simulador\n(Workstation CCO-test)" as SIM_NODE {
    artifact "bus-simulator.jar" as BUS_JAR
    component "SITM.Main — Bus Simulator\n[Ice client → DatagramReceiverPrx]" as BS_MAIN
    note bottom of BS_MAIN
      Lee CSV cada 500 ms
      Construye Datagram (12 campos)
      PathResolver:  ruta exacta
        → /opt/sitm-mio/<nombre>
        → data/<nombre>
    end note
  }

  node "Nodo Event Processor\n[Ice Servant — TCP :10000\nidentidad: DatagramReceiver]" as EP_NODE {
    artifact "event-processor.jar" as EP_JAR
    component "DatagramReceiverI\n[Pub-Sub Broker]" as EP_SERV
    component "List<MonitoringSubscriberPrx>\n[Registro dinámico de suscriptores]" as PUBSUB_REG
    note right of EP_SERV
      postDatagram(d):
        lat = d.latitude  / 10 000 000.0
        lon = d.longitude / 10 000 000.0
        archiveDatagramAsync(d)  ← AMI
        notify(BusUpdate)
      subscribe(sub): agrega proxy
      notify(): itera lista, elimina
        suscriptores con LocalException
    end note
  }

  node "Nodo Data Center\n[Ice Servant — TCP :10001\nidentidades: ArchiveService, ReportProvider]" as DC_NODE {
    artifact "data-center.jar" as DC_JAR
    component "ArchiveServiceI\n[Servant Ice / AMI]" as ARCH_SERV
    component "ReportProviderI\n[Servant Ice]" as REPORT_SERV
    database "DataWarehouse\nArrayList<Datagram>\n(en memoria — synchronized)" as DW
    note right of REPORT_SERV
      getAverageSpeed(lineId, month, year):
        groupByTrip → ordena por datagramDate
        Σ(Δodómetro) / Σ(Δsegundos) × 3.6
        filtra kmh > 120 (atípicos)
    end note
  }

  node "Nodo Visualizador — Escritorio CCO\n[Ice Servant — puerto dinámico vía cfg]" as VIZ_NODE {
    artifact "visualizer-client.jar" as VIZ_JAR
    component "SITM.Launcher → SITM.Main\n[JavaFX Application]" as VIZ_APP
    component "MonitoringSubscriberI\n[Callback Ice — endpoint dinámico]" as MSUB
    component "JavaFX Stage + WebView\n(WebKit embebido)" as JFX_VIEW
    component "map.html  ·  Leaflet.js 1.9.4\n+ OpenStreetMap tiles" as MAP_HTML
    database "markers{ busId → CircleMarker }\n(estado JS en memoria)" as MARKERS_STATE
    note right of VIZ_APP
      initIce():
        propertyToProxy(EventProcessor.Proxy)
        DatagramReceiverPrx.checkedCast()
        createObjectAdapterWithEndpoints()
        adapter.add(MonitoringSubscriberI)
        receiver.subscribe(callbackProxy)
      onUpdate(BusUpdate u):
        Platform.runLater(() ->
          webEngine.executeScript(
            "updateBus(id,lat,lng,line,ts)"))
    end note
    note bottom of MAP_HTML
      tryInit() polling:
        espera offsetWidth > 100 px
        antes de L.map() para evitar
        tiles dispersos en JavaFX WebView
        CSS: #map { 100vw / 100vh }
    end note
  }
}

' ============================================================
' SUBSISTEMA B — CÁLCULO DE VELOCIDADES
' ============================================================
package "Subsistema B — Cálculo de Velocidades  (V1 Monolítica · V2 Concurrente · V3 Distribuida)" as SPEED_PKG #E8EAF6 {

  node "Nodo Análisis — V1 y V2\n(1 máquina, standalone)" as CALC_NODE {
    artifact "speed-calculator.jar" as CALC_JAR
    component "SpeedCalculatorV1\n[Secuencial — 1 hilo]" as V1_COMP
    component "SpeedCalculatorV2\n[ExecutorService\nN = availableProcessors()]" as V2_COMP
    component "SpeedEngine\n[Lógica compartida V1/V2]" as SE_COMP
    note right of V2_COMP
      Fork-Join por lineId:
        pool.submit(() ->
          SpeedEngine.computeForLine(lineId, data))
        Future<List<SpeedResult>>
      Speedup real ≈ 0.7–0.85 × N cores
    end note
  }

  node "Nodo Master — V3\n(Coordinador Scatter-Gather)" as MASTER_NODE {
    artifact "speed-master.jar" as MASTER_JAR
    component "SITM.Main — Master\n[Scatter-Gather / ExecutorService]" as MASTER_COMP
    note right of MASTER_COMP
      1. Lee speed-master.cfg:
         Worker.Count, Worker.0..N
      2. checkedCast (descarta no disponibles)
      3. groupByLineId(csv)
      4. round-robin: Worker[i % N]
         ← datagramas de lineIds[i]
      5. pool.submit(() ->
           worker.computeSpeeds(partition[i]))
      6. Future.get() agrega SpeedReport[]
      7. Ordena lineId/año/mes → imprime
    end note
  }

  node "Nodo Worker 0\n[Ice Servant — TCP :10100\nidentidad: SpeedWorker]" as W0_NODE {
    artifact "speed-worker.jar" as W0_JAR
    component "SpeedWorkerI — Worker 0" as SW0_COMP
  }

  node "Nodo Worker 1\n[Ice Servant — TCP :10101\nidentidad: SpeedWorker1]" as W1_NODE {
    artifact "speed-worker.jar" as W1_JAR
    component "SpeedWorkerI — Worker 1" as SW1_COMP
    note right of SW1_COMP
      computeSpeeds(partition):
        groupByTrip(datagramas)
        ordena por datagramDate
        Σ(Δodóm.) / Σ(Δseg.) × 3.6
        filtra > 120 km/h
        retorna SpeedReport[]
    end note
  }

  node "Nodo Worker N\n[Ice Servant — TCP :101XX]\n(escalado horizontal)" as WN_NODE {
    component "SpeedWorkerI — Worker N\n(misma lógica, puerto distinto)" as SWN_COMP
    note right of SWN_COMP
      Para agregar Worker N:
        editar speed-master.cfg:
          Worker.Count = N+1
          Worker.N =
            SpeedWorker:default
              -h <host> -p 101XX
        Sin cambios de código
    end note
  }
}

' ============================================================
' RELACIONES — SUBSISTEMA A (MONITOREO)
' ============================================================

CSV_MINI -right-> BS_MAIN : lee línea a línea\n(PathResolver)

BS_MAIN -right-> EP_SERV : <<Ice RPC TCP :10000>>\npostDatagram(Datagram)

EP_SERV -right-> PUBSUB_REG : mantiene

EP_SERV -down-> ARCH_SERV : <<Ice AMI async>>\narchiveDatagramAsync(Datagram)\n[no bloquea el hilo de notify]

ARCH_SERV -down-> DW : store(Datagram)

EP_SERV -right-> MSUB : <<Ice RPC callback — puerto dinámico>>\nupdateLocation(BusUpdate)

MSUB -down-> VIZ_APP : Platform.runLater()\n[hilo JavaFX UI]

VIZ_APP -right-> JFX_VIEW : webEngine\n.executeScript(\n"updateBus(...)")

JFX_VIEW -right-> MAP_HTML : evalúa JS

MAP_HTML -down-> MARKERS_STATE : markers[busId]\n.setLatLng(pos)

VIZ_APP -down-> REPORT_SERV : <<Ice RPC TCP :10001>>\ngetAverageSpeed(lineId, month, year)

REPORT_SERV -right-> DW : query\ngroupByTrip

' ============================================================
' RELACIONES — SUBSISTEMA B V1/V2
' ============================================================

CSV_MINI -down-> V1_COMP : lee (secuencial)
CSV_MINI -down-> V2_COMP : lee (concurrente)
V1_COMP -right-> SE_COMP : delega
V2_COMP -right-> SE_COMP : delega\n(un Future por lineId)

' ============================================================
' RELACIONES — SUBSISTEMA B V3
' ============================================================

CSV_MINI -down-> MASTER_COMP : lee y particiona\n(round-robin por lineId)
CSV_FULL ..> MASTER_COMP : (dataset completo\nalternativo)

MASTER_COMP -right-> SW0_COMP : <<Ice RPC TCP :10100>>\ncomputeSpeeds(DatagramSeq)\nretorna: SpeedReportSeq

MASTER_COMP -right-> SW1_COMP : <<Ice RPC TCP :10101>>\ncomputeSpeeds(DatagramSeq)\nretorna: SpeedReportSeq

MASTER_COMP -right-> SWN_COMP : <<Ice RPC TCP :101XX>>\ncomputeSpeeds(DatagramSeq)\nretorna: SpeedReportSeq

' ============================================================
' DEPENDENCIAS DE COMPILACIÓN — contracts.jar
' ============================================================

CONTRACTS_JAR .down.> BUS_JAR   : <<compile>>
CONTRACTS_JAR .down.> EP_JAR    : <<compile>>
CONTRACTS_JAR .down.> DC_JAR    : <<compile>>
CONTRACTS_JAR .down.> VIZ_JAR   : <<compile>>
CONTRACTS_JAR .down.> MASTER_JAR: <<compile>>
CONTRACTS_JAR .down.> W0_JAR    : <<compile>>
CONTRACTS_JAR .down.> W1_JAR    : <<compile>>

' ============================================================
' NOTA: PUERTOS Y ARCHIVOS DE CONFIGURACIÓN
' ============================================================
note as PORTS_NOTE
  <b>Puertos ICE registrados:</b>
  :10000  DatagramReceiver  (event-processor)
  :10001  ArchiveService + ReportProvider  (data-center)
  :10100  SpeedWorker      (speed-worker instancia 0)
  :10101  SpeedWorker1     (speed-worker instancia 1)
  dinámico MonitoringSubscriberI  (visualizer-client)

  <b>Archivos .cfg por módulo:</b>
  bus-simulator.cfg      EventProcessor.Proxy = ...:10000
  event-processor.cfg    endpoints :10000
                         DataCenter.Proxy = ...:10001
  data-center.cfg        endpoints :10001
  visualizer-client.cfg  EventProcessor.Proxy = ...:10000
                         ReportProvider.Proxy = ...:10001
  speed-worker.cfg       SpeedWorker.Endpoints = ...:10100
  speed-master.cfg       Worker.Count = 2
                         Worker.0 = SpeedWorker:...:10100
                         Worker.1 = SpeedWorker:...:10101

  <b>Patrón de comunicación:</b>
  Bus Sim → EP : Ice RPC síncrono  (postDatagram)
  EP → DC      : Ice AMI asíncrono (archiveDatagram)
  EP → Viz     : Ice RPC callback  (updateLocation)
  Master → Wk  : Ice RPC síncrono  (computeSpeeds)
end note

@enduml
