@startuml SITM-MIO_Architecture_Complete

' ============================================================
' CONFIG GLOBAL
' ============================================================
!theme plain
skinparam linetype ortho
skinparam backgroundColor #FFFFFF
skinparam defaultFontSize 10
skinparam defaultFontName Arial
skinparam padding 5
skinparam ranksep 45
skinparam nodesep 25

skinparam node {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  BorderThickness 2
  FontStyle bold
}
skinparam component {
  BackgroundColor #FFF9C4
  BorderColor #F57F17
}
skinparam database {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
}
skinparam artifact {
  BackgroundColor #FCE4EC
  BorderColor #B71C1C
}
skinparam package {
  BorderColor #6A1B9A
  BorderThickness 2
  FontStyle bold
}
skinparam note {
  BackgroundColor #FFFDE7
  BorderColor #F9A825
}
skinparam arrow {
  Color #37474F
  FontSize 9
}
skinparam file {
  BackgroundColor #F3E5F5
  BorderColor #6A1B9A
}

title "SITM-MIO — Diagrama de Despliegue Completo\nZeroC Ice 3.7.10  ·  Java 17  ·  Gradle 8.6  ·  Leaflet.js 1.9.4"

' ============================================================
' CAPA 0 — DATOS Y CONTRATOS (fila superior)
' ============================================================
package "Datos de Entrada (CSV)" as DATA_PKG #F5F5F5 {
  file "datagrams-MiniPilot.csv" as CSV_MINI
  file "datagrams4Pilot.csv" as CSV_FULL
}

package "contracts — sitm.ice → Ice-Builder → Java" as CONTRACTS_PKG #FFF3E0 {
  artifact "contracts.jar\n────────────────────\nDatagramReceiver\nArchiveService  [ami]\nMonitoringSubscriber\nReportProvider\nSpeedWorker\n────────────────────\nstructs: Datagram,\nBusUpdate, SpeedReport\nseqs: DatagramSeq,\nSpeedReportSeq" as CONTRACTS_JAR
}

' ============================================================
' SUBSISTEMA A — MONITOREO (columna izquierda)
' ============================================================

node "bus-simulator  [Simulador CSV]" as SIM_NODE {
  component "SITM.Main — Bus Simulator\nlee CSV · postDatagram() cada 500 ms\nPathResolver: ruta exacta → /opt/sitm-mio/ → data/" as BS_MAIN
}

node "event-processor\n[TCP :10000 · DatagramReceiver]" as EP_NODE {
  component "DatagramReceiverI  [Broker Pub-Sub]\npostDatagram(): normaliza lat,lon ÷ 10 000 000\narchiveDatagramAsync() → AMI\nnotify(): BusUpdate a suscriptores activos\ntoleancia a fallos: elimina con LocalException" as EP_SERV
}

node "data-center\n[TCP :10001 · ArchiveService + ReportProvider]" as DC_NODE {
  component "ArchiveServiceI  [AMI]" as ARCH_SERV
  component "ReportProviderI\ngetAverageSpeed(lineId, month, year)\ngetMonthlyReports(year)" as REPORT_SERV
  database "DataWarehouse\nArrayList<Datagram>  (synchronized, en memoria)" as DW
}

node "visualizer-client  [Escritorio CCO · puerto dinámico]" as VIZ_NODE {
  component "MonitoringSubscriberI  [Callback Ice]\nPlatform.runLater() → hilo JavaFX UI" as MSUB
  component "JavaFX Stage + WebView\nmap.html · Leaflet.js 1.9.4 · OpenStreetMap\nCSS: 100vw/100vh · tryInit() polling\nstage.setOnShown() → forceResize() +400 ms" as MAP_HTML
}

' ============================================================
' SUBSISTEMA B — VELOCIDADES (columna derecha)
' ============================================================

node "speed-calculator  [V1 y V2 · Standalone]" as CALC_NODE {
  component "SpeedCalculatorV1  [1 hilo, secuencial]" as V1_COMP
  component "SpeedCalculatorV2  [ExecutorService · N = availableProcessors()]" as V2_COMP
  component "SpeedEngine  [algoritmo compartido V1/V2\ngroupByTrip → Σ(Δodóm)/Σ(Δseg)×3.6\nfiltra kmh > 120]" as SE_COMP
}

node "speed-master  [Master · Scatter-Gather]" as MASTER_NODE {
  component "SITM.Main — Master\nlee speed-master.cfg: Worker.Count, Worker.0..N\ncheckedCast · round-robin por lineId\nExecutorService · Future<SpeedReportSeq>" as MASTER_COMP
}

node "speed-workers  [N Workers Ice · TCP :1010X]" as WORKERS_NODE {
  component "SpeedWorkerI — Worker 0  (:10100)" as SW0_COMP
  component "SpeedWorkerI — Worker 1  (:10101)" as SW1_COMP
  component "SpeedWorkerI — Worker N  (:101XX)\n[escala horizontal solo con .cfg]" as SWN_COMP
}

' ============================================================
' RELACIONES — SUBSISTEMA A
' ============================================================
CSV_MINI -down-> BS_MAIN       : PathResolver
BS_MAIN  -down-> EP_SERV       : <<Ice RPC :10000>>\npostDatagram(Datagram)
EP_SERV  -down-> ARCH_SERV     : <<Ice AMI async>>\narchiveDatagramAsync(Datagram)
ARCH_SERV -down-> DW            : store(Datagram)
REPORT_SERV -left-> DW          : query → groupByTrip
EP_SERV  -right-> MSUB          : <<Ice callback>>\nupdateLocation(BusUpdate)
MSUB     -down-> MAP_HTML        : webEngine.executeScript\n("updateBus(id,lat,lng,line,ts)")
VIZ_NODE -up-> REPORT_SERV      : <<Ice RPC :10001>>\ngetAverageSpeed(lineId,m,y)

' ============================================================
' RELACIONES — SUBSISTEMA B
' ============================================================
CSV_MINI   -down-> V1_COMP       : lee (secuencial)
CSV_MINI   -down-> V2_COMP       : lee (concurrente)
V1_COMP    -down-> SE_COMP       : delega por lineId
V2_COMP    -down-> SE_COMP       : Future<List<SpeedResult>> por lineId

CSV_MINI   -down-> MASTER_COMP   : lee y particiona
MASTER_COMP -down-> SW0_COMP     : <<Ice RPC :10100>>\ncomputeSpeeds(DatagramSeq)
MASTER_COMP -down-> SW1_COMP     : <<Ice RPC :10101>>\ncomputeSpeeds(DatagramSeq)
MASTER_COMP -down-> SWN_COMP     : <<Ice RPC :101XX>>\ncomputeSpeeds(DatagramSeq)

' ============================================================
' DEPENDENCIAS DE COMPILACIÓN
' ============================================================
CONTRACTS_JAR .down.> SIM_NODE      : <<compile>>
CONTRACTS_JAR .down.> EP_NODE       : <<compile>>
CONTRACTS_JAR .down.> DC_NODE       : <<compile>>
CONTRACTS_JAR .down.> VIZ_NODE      : <<compile>>
CONTRACTS_JAR .down.> MASTER_NODE   : <<compile>>
CONTRACTS_JAR .down.> WORKERS_NODE  : <<compile>>
CONTRACTS_JAR .down.> CALC_NODE     : <<compile>>

' ============================================================
' NOTA DE REFERENCIA — PUERTOS Y CONFIGURACIÓN
' ============================================================
note as PORTS_NOTE
  <b>Puertos Ice registrados:</b>
  :10000  DatagramReceiver    (event-processor)
  :10001  ArchiveService +
          ReportProvider      (data-center)
  :10100  SpeedWorker-0       (speed-worker)
  :10101  SpeedWorker-1       (speed-worker)
  dinám.  MonitoringSubscriberI (visualizer-client)

  <b>Archivos .cfg por módulo:</b>
  bus-simulator.cfg     EventProcessor.Proxy = ...:10000
  event-processor.cfg   endpoints :10000
                        DataCenter.Proxy = ...:10001
  data-center.cfg       endpoints :10001
  visualizer-client.cfg EventProcessor.Proxy = ...:10000
                        ReportProvider.Proxy = ...:10001
  speed-worker.cfg      SpeedWorker.Endpoints = ...:10100
  speed-master.cfg      Worker.Count = 2
                        Worker.0 = SpeedWorker:...:10100
                        Worker.1 = SpeedWorker:...:10101
end note

@enduml
